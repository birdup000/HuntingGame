# GameConfig.prc - Additional Panda3D runtime settings for the hunting game
# NOTE: This file is NOT auto-loaded by Panda3D (only Config.prc in root is).
# It serves as documentation and is loaded manually if needed.

# Window settings
win-size 1200 800
window-title 3D Hunting Simulator

# Frame rate
sync-video #t
frame-rate-meter-scale 0.02

# Graphics features
support-particles #t
